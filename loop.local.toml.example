# これを loop.local.toml にコピーして編集する(loop.local.toml は gitignore)。
# load_config が loop.toml にマージする。リポジトリ構成はすべてここ(ローカル)に置く。

# [repos] にこのマシンの git リポジトリを登録する。タスクの repo: に「名前」を書くと解決され、
# Web の repo セレクタにも並ぶ。
[repos]
# myproject = "/Users/me/Documents/GitHub/myproject"
# infra     = "~/work/infra"
#
# 値はパス文字列(= worktree 並列。既定)か、{ path, mode } テーブルで指定する。
# mode = "serial" にすると、その repo は worktree を作らず本体で 1 本ずつ作業する。
# Unity など worktree にチェックアウトしても Library 等(gitignore)が無く再 import が走り、
# 共有 .git のメタも揺れる repo 向け。runner だけがこの違いを意識する(タスク生成・記憶は不変)。
# 成果は loop/<id> ブランチに残り、run 後は元ブランチへ戻る(本体を汚さない)。
# 同一 serial repo の run は同時 1 本に直列化される(他 repo / 並列 repo とは並行)。
# myunity = { path = "/Users/me/Documents/GitHub/MyUnityGame", mode = "serial" }

# (任意)タスクが repo を指定しなかったときのデフォルト対象。未設定なら "."(loop 自身)。
# [repo]
# path = "myproject"

# (任意・複数 PC 運用)契約データを host 別ディレクトリに分けて衝突なく同期する。
# 既定は "data"(repo root)。複数 PC で同じ data repo を共有するときは host 別パスを指す。
# 各 PC は自分のディレクトリだけ書くので git pull --rebase --autostash で衝突せず同期できる。
# [data]
# dir = "data/hosts/<this-host>"

# (任意・複数 PC 運用)Fleet: 1 つの Web GUI から全 PC を扱う。peers が空なら単一 PC 表示のまま。
# url は各 PC の Next フロント(Tailnet 経由)を指す。各 PC は自分自身も peers に含める。
# Fleet 画面は peers の /api/* を並列 fetch し host バッジ付きで merge view を出す。
# [fleet]
# self = "<this-host>"
# peers = [
#   { name = "<this-host>",  url = "http://<this-host>.<tailnet>.ts.net:3000" },
#   { name = "<other-mac>",  url = "http://<other-mac>.<tailnet>.ts.net:3000" },
# ]
