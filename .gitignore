.DS_Store
__pycache__/
*.pyc
# worktree は対象 repo に依らずこの loop repo 内に固定配置し ignore(data/ と同じ方針)
.loop-worktrees/
# 契約データは別の private git repo(エンジン=公開 repo には含めない)
data/
# WatchPaths ログ / launchd plist は環境ローカルに生成される
.watch.log
launchd/com.loop.watch.plist
# Next.js フロント(web/)の Node 依存とビルド成果物
web/node_modules/
web/.next/
web/out/
web/.env.local
web/next-env.d.ts
web/tsconfig.tsbuildinfo
